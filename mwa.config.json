{
  "models": {
    "fetch": "gpt-5-4-mini",
    "reason": "gpt-5-4-mini"
  },
  "awm": {},
  "tools": {
    "builtins": [
      "run_command",
      "read_file",
      "write_file",
      "list_files",
      "read_document"
    ],
    "mcpServers": {
      "search": {
        "command": "node",
        "args": [
          "mcp-servers/search.mjs"
        ]
      },
      "fetch": {
        "command": "node",
        "args": [
          "mcp-servers/fetch.mjs"
        ]
      }
    }
  },
  "escalation": {
    "maxFetchFailures": 2
  }
}
