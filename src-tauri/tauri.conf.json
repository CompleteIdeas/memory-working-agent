{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MWA",
  "version": "0.1.0",
  "identifier": "com.completeideas.mwa",
  "build": {
    "frontendDist": "../dist-ui",
    "devUrl": "http://localhost:7788",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": { "../build/runtime-stage": "runtime" },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
