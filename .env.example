# Copy to .env (next to docker-compose.yml) and edit. Compose reads it automatically.
# This file holds ONLY the deployment knobs — your AI provider keys are entered in the
# guided setup screen in the browser and stored on the /data volume, never here.

# Locks the UI + API behind one shared password. Set a strong value for any NAS /
# networked deployment. Leave blank only if access is already private (Tailscale-only).
MWA_ACCESS_PASSWORD=

# Timezone for scheduled ("every day at 7am…") tasks.
TZ=America/New_York
